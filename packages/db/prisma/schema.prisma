generator client {
  provider = "prisma-client"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id                  String                @id @default(uuid()) @db.Uuid
  name                String
  repositoryStatus    RepositoryStatus      @default(not_connected) @map("repository_status")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")
  repositoryConnection RepositoryConnection?

  @@map("projects")
}

model RepositoryConnection {
  id                  String              @id @default(uuid()) @db.Uuid
  projectId           String              @unique @map("project_id") @db.Uuid
  provider            RepositoryProvider
  repositoryOwner     String              @map("repository_owner")
  repositoryName      String              @map("repository_name")
  repositoryId        String?             @map("repository_id")
  defaultBranch       String              @map("default_branch")
  credentialReference String              @map("credential_reference")
  connectedAt         DateTime            @map("connected_at")
  lastVerifiedAt      DateTime            @map("last_verified_at")
  createdBy           String              @map("created_by")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedBy           String              @map("updated_by")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  project             Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("repository_connections")
}

model AuditEntry {
  id            String   @id @default(uuid()) @db.Uuid
  action        String
  actorId       String   @map("actor_id")
  correlationId String   @map("correlation_id")
  metadata      Json
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("audit_entries")
}

enum RepositoryProvider {
  github
  gitlab
}

enum RepositoryStatus {
  connected
  not_connected
}
